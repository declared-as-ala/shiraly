# ===========================================
# Public site config
# ===========================================
NEXT_PUBLIC_SITE_NAME=Shiraly
NEXT_PUBLIC_SITE_URL=https://shiraly.tn
NEXT_PUBLIC_CURRENCY_CODE=TND
NEXT_PUBLIC_CURRENCY_SYMBOL=DT

# ===========================================
# MongoDB (required)
# ===========================================
MONGODB_URI=mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/shiraly

# ===========================================
# Cloudinary (for image uploads)
# ===========================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===========================================
# Navex shipping API — https://navex.tn
# ===========================================
NAVEX_API_BASE=https://app.navex.tn
NAVEX_TOKEN_ADD=
NAVEX_TOKEN_GET=
NAVEX_TOKEN_DELETE=
NAVEX_AUTO_PUSH_LABEL=navex

# ===========================================
# First Delivery Group API
# ===========================================
FIRST_DELIVERY_API_BASE=https://www.firstdeliverygroup.com/api/v2
FIRST_DELIVERY_TOKEN=
FIRST_DELIVERY_AUTO_PUSH_LABEL=firstdelivery

# ===========================================
# Admin auth
# ===========================================
ADMIN_PASSWORD=change-me
SESSION_SECRET=change-me-32-bytes-min
