# ===========================================
# Public site config
# ===========================================
NEXT_PUBLIC_SITE_NAME=Shiraly
NEXT_PUBLIC_SITE_URL=https://shiraly.tn
NEXT_PUBLIC_CURRENCY_CODE=TND
NEXT_PUBLIC_CURRENCY_SYMBOL=DT

# ===========================================
# MongoDB (required)
# ===========================================
MONGODB_URI=mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/shiraly

# ===========================================
# Cloudinary (for image uploads)
# ===========================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===========================================
# Admin auth
# ===========================================
SESSION_SECRET=change-me-32-bytes-min
# Optional: email/password for the first bootstrapped admin account
ADMIN_PASSWORD=change-me
ADMIN_EMAIL=admin@shiraly.tn

# ===========================================
# Best Delivery (SOAP) — backend only, never expose to frontend
# Docs: https://doc.best-delivery.net/
# ===========================================
BEST_DELIVERY_LOGIN=
BEST_DELIVERY_PASSWORD=
BEST_DELIVERY_WSDL_URL=https://api.best-delivery.net/serviceShipments.php?wsdl
# Override only if the live WSDL declares a different target namespace
# BEST_DELIVERY_NAMESPACE=urn:serviceShipments
