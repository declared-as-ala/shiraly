# ===========================================
# Public site config
# ===========================================
NEXT_PUBLIC_SITE_NAME=Shiraly
NEXT_PUBLIC_SITE_URL=https://shiraly.tn
NEXT_PUBLIC_CURRENCY_CODE=TND
NEXT_PUBLIC_CURRENCY_SYMBOL=DT

# ===========================================
# MongoDB (required)
# ===========================================
MONGODB_URI=mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/shiraly

# ===========================================
# Cloudinary (for image uploads)
# ===========================================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===========================================
# Admin auth
# ===========================================
SESSION_SECRET=change-me-32-bytes-min
